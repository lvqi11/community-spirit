# Community Spirit currently runs with public synthetic data only.
# Add real API keys only in local .env files, never in public commits.
VITE_COMMUNITY_SPIRIT_DATA_MODE=synthetic

# Optional for Mind the Product World Product Day / Novus.ai validation.
# Leave blank unless you have the Pendo/Novus web SDK key from your account.
VITE_PENDO_API_KEY=
