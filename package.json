{
  "name": "community-spirit",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:lifecycle": "node scripts/validate-pulse-lifecycle.mjs",
    "validate:retention": "node scripts/validate-retention.mjs",
    "validate:protocol": "node scripts/validate-cacp.mjs",
    "validate:protocol:portable": "node scripts/validate-cacp-portable-extraction.mjs",
    "validate:submission": "node scripts/validate-submission.mjs",
    "check": "npm run validate:data && npm run validate:lifecycle && npm run validate:retention && npm run validate:protocol && node --check demo/web/app.js && npm run build && npm run validate:submission"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {}
}
