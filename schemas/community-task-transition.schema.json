{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://community-spirit.dev/schemas/community-task-transition.v0.1.json",
  "title": "Community Task Transition",
  "description": "A requested CACP lifecycle state change with its supporting evidence and outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "transition_id", "contract_id", "requested_by", "from_state", "to_state", "occurred_at", "reason", "evidence_ids", "artifact_ids", "data_policy"],
  "properties": {
    "schema_version": { "const": "cacp.community_task_transition.v0.1" },
    "transition_id": { "type": "string", "pattern": "^transition-[a-z0-9-]+$" },
    "contract_id": { "type": "string", "pattern": "^ctc-[a-z0-9-]+$" },
    "requested_by": { "type": "string", "pattern": "^actor-[a-z0-9-]+$" },
    "from_state": { "type": "string" },
    "to_state": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "reason": { "type": "string", "minLength": 10 },
    "evidence_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^evidence-[a-z0-9-]+$" } },
    "artifact_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^artifact-[a-z0-9-]+$" } },
    "data_policy": { "const": "fictional_or_synthetic_only" }
  }
}
