{
  "schema_version": "cacp.community_actor_card.v0.1",
  "actor_id": "actor-community-ai-assistant",
  "actor_type": "ai_agent",
  "display_name": "Synthetic Community AI Assistant",
  "capabilities": ["activity_discovery", "route_guidance", "task_proposal", "governance_suggestion", "human_handoff"],
  "supported_interaction_modes": ["solo", "parallel", "operator"],
  "allowed_zones": ["community_public_space", "shared_operations_area"],
  "forbidden_zones": ["private_home", "restricted_operations_area", "unapproved_route"],
  "requires_human_approval": true,
  "data_boundaries": {
    "real_identity_access": false,
    "camera_access": false,
    "raw_video_storage": false,
    "resident_profile_access": false,
    "notes": ["Suggests synthetic community tasks and never approves or executes them without a human operator."]
  },
  "safety_controls": {
    "human_handoff": true,
    "manual_stop": true,
    "audit_log": true
  },
  "data_policy": "fictional_or_synthetic_only"
}
